{
  "name": "beauty-platform",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "dev:worker": "npm --workspace apps/worker run dev",
    "lint": "npm --workspace apps/web run lint",
    "test:aisha-dialogs": "node scripts/aisha-dialog-regression.mjs --suite=all",
    "test:aisha-dialogs:core": "node scripts/aisha-dialog-regression.mjs --suite=core",
    "test:aisha-dialogs:booking": "node scripts/aisha-dialog-regression.mjs --suite=booking-e2e",
    "test:aisha-dialogs:client": "node scripts/aisha-dialog-regression.mjs --suite=client-actions",
    "prisma:studio": "powershell -ExecutionPolicy Bypass -File ./studio.ps1",
    "prisma:validate": "powershell -ExecutionPolicy Bypass -File ./scripts/prisma.ps1 validate",
    "test:aisha-dialogs:super": "node scripts/aisha-dialog-regression.mjs --suite=super",
    "test:aisha-dialogs:matrix": "node scripts/aisha-dialog-matrix.mjs",
    "test:aisha-dialogs:max": "npm run test:aisha-dialogs && npm run test:aisha-dialogs:super && npm run test:aisha-dialogs:matrix",
    "seed:ru": "node scripts/reseed-russian-salon.js",
    "seed:ru:full": "node scripts/reseed-russian-salon-full.js"
  },
  "devDependencies": {
    "prisma": "^6.19.1"
  },
  "dependencies": {
    "@prisma/client": "^6.19.1"
  }
}
