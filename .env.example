POSTGRES_DB=beauty_platform
POSTGRES_USER=beauty_user
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_PORT=5432
DATABASE_URL=postgresql://beauty_user:CHANGE_ME@localhost:5432/beauty_platform

# GigaChat (Сбер) API
# Base64(client_id:client_secret) из кабинета GigaChat
GIGACHAT_AUTH_KEY=
# Пример: GigaChat, GigaChat-Pro
GIGACHAT_MODEL=GigaChat
# Необязательные кастомные эндпоинты
GIGACHAT_AUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
GIGACHAT_API_URL=https://gigachat.devices.sberbank.ru/api/v1/chat/completions
# Только для разработки: пропуск проверки TLS, если локальная цепочка сертификатов сломана.
# Не включать в продакшене.
GIGACHAT_ALLOW_INSECURE_TLS=false

# Публичная запись / ИИ ассистент
AI_THREAD_SECRET=
# Обязательно задать для подписи hold-токенов публичной записи.
PUBLIC_BOOKING_HOLD_SECRET=
SESSION_SECRET=
NEXTAUTH_SECRET=

# Необязательно: скрипты для тестирования диалогов ИИ
AISHA_BASE_URL=http://localhost:3000
AISHA_ACCOUNT=
AISHA_TIMEOUT_MS=15000
AISHA_SUITE=all
