POSTGRES_DB=beauty_platform
POSTGRES_USER=beauty_user
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_PORT=5432
DATABASE_URL=postgresql://beauty_user:CHANGE_ME@localhost:5432/beauty_platform

# GigaChat (Sber) API
# Base64(client_id:client_secret) from GigaChat cabinet
GIGACHAT_AUTH_KEY=
# Example: GigaChat, GigaChat-Pro
GIGACHAT_MODEL=GigaChat
# Optional custom endpoints
GIGACHAT_AUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
GIGACHAT_API_URL=https://gigachat.devices.sberbank.ru/api/v1/chat/completions
# Dev-only fallback: skip TLS verification when local cert chain is broken.
# Do not enable in production.
GIGACHAT_ALLOW_INSECURE_TLS=false
