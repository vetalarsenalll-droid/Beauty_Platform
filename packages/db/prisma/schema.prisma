// Prisma schema for Beauty Platform (single source of truth)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum UserStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum UserType {
  STAFF
  CLIENT
}

enum RoleName {
  OWNER
  MANAGER
  SPECIALIST
  READONLY
}

enum AppointmentStatus {
  NEW
  CONFIRMED
  IN_PROGRESS
  DONE
  CANCELLED
  NO_SHOW
}

enum PaymentIntentStatus {
  CREATED
  REQUIRES_ACTION
  PROCESSING
  SUCCEEDED
  FAILED
  CANCELLED
  EXPIRED
}

enum TransactionType {
  CHARGE
  REFUND
  CAPTURE
  VOID
  OFFLINE_PAYMENT
}

enum RefundStatus {
  PENDING
  SUCCEEDED
  FAILED
}

enum NotificationChannel {
  IN_APP
  EMAIL
  TELEGRAM
  MAX
  PUSH
  SMS
  WEBHOOK
  SSE
}

enum DeliveryStatus {
  QUEUED
  SENT
  FAILED
  DEAD
}

enum OutboxStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
  DEAD
}

enum WebhookStatus {
  ACTIVE
  PAUSED
  DISABLED
}

enum PublicPageStatus {
  DRAFT
  PUBLISHED
}

enum TemplateType {
  NOTIFICATION
  SEO_PRESET
  CONSTRUCTOR_PRESET
}

enum ScheduleEntryType {
  WORKING
  SICK
  VACATION
  UNPAID_OFF
  NO_SHOW
  PAID_OFF
  CUSTOM
}

enum NotificationScope {
  PLATFORM
  ACCOUNT
  USER
}

enum AudienceType {
  CLIENT
  STAFF
  PLATFORM_ADMIN
}

enum PromotionType {
  PERCENT
  FIXED
  BUNDLE
}

enum PromoRedemptionStatus {
  APPLIED
  CANCELLED
}

enum LoyaltyTransactionType {
  EARN
  SPEND
  EXPIRE
  ADJUSTMENT
  REFUND_REVERSAL
}

enum GiftCardStatus {
  ACTIVE
  REDEEMED
  EXPIRED
  CANCELLED
}

enum MembershipType {
  COUNT
  PERIOD
}

enum IdentityProvider {
  EMAIL
  PHONE
  TELEGRAM
  MAX
}

enum SessionType {
  PLATFORM
  CRM
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  VOID
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
}

enum OutboxScope {
  PLATFORM
  ACCOUNT
  USER
}
model PlatformPlan {
  id Int @id @default(autoincrement())
  name          String
  code          String                 @unique
  description   String?
  priceMonthly  Decimal                @db.Decimal(12, 2)
  currency      String                 @default("RUB")
  isActive      Boolean                @default(true)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  features      PlatformPlanFeature[]
  subscriptions PlatformSubscription[]
  accounts      Account[]
}

model PlatformPlanFeature {
  id Int @id @default(autoincrement())
  planId Int
  key       String
  value     String?
  createdAt DateTime @default(now())

  plan PlatformPlan @relation(fields: [planId], references: [id])

  @@unique([planId, key])
}

model PlatformSubscription {
  id Int @id @default(autoincrement())
  accountId Int
  planId Int
  status        SubscriptionStatus @default(ACTIVE)
  startedAt     DateTime           @default(now())
  endsAt        DateTime?
  nextBillingAt DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  account Account      @relation(fields: [accountId], references: [id])
  plan    PlatformPlan @relation(fields: [planId], references: [id])
  invoices PlatformInvoice[]

  @@index([accountId, status])
}

model PlatformInvoice {
  id Int @id @default(autoincrement())
  accountId Int
  subscriptionId Int?
  status         InvoiceStatus @default(DRAFT)
  amount         Decimal       @db.Decimal(12, 2)
  currency       String        @default("RUB")
  issuedAt       DateTime?
  dueAt          DateTime?
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  account      Account               @relation(fields: [accountId], references: [id])
  subscription PlatformSubscription? @relation(fields: [subscriptionId], references: [id])
  payments     PlatformPayment[]

  @@index([accountId, status])
}

model PlatformPayment {
  id Int @id @default(autoincrement())
  invoiceId Int?
  amount      Decimal       @db.Decimal(12, 2)
  currency    String        @default("RUB")
  status      PaymentStatus @default(PENDING)
  provider    String?
  providerRef String?
  createdAt   DateTime      @default(now())

  invoice PlatformInvoice? @relation(fields: [invoiceId], references: [id])
}

model PlatformLimit {
  id Int @id @default(autoincrement())
  accountId Int
  key       String
  valueInt  Int?
  valueJson Json?
  createdAt DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id])

  @@unique([accountId, key])
}

model PlatformAdmin {
  id Int @id @default(autoincrement())
  userId Int     @unique
  status    UserStatus @default(ACTIVE)
  createdAt DateTime   @default(now())

  user        User                                @relation(fields: [userId], references: [id])
  permissions PlatformAdminPermissionAssignment[]
  audits      PlatformAuditLog[]
}

model PlatformPermission {
  id Int @id @default(autoincrement())
  key         String   @unique
  description String?
  createdAt   DateTime @default(now())

  assignments PlatformAdminPermissionAssignment[]
}

model PlatformAdminPermissionAssignment {
  id Int @id @default(autoincrement())
  adminId Int
  permissionId Int
  createdAt    DateTime @default(now())

  admin      PlatformAdmin      @relation(fields: [adminId], references: [id])
  permission PlatformPermission @relation(fields: [permissionId], references: [id])

  @@unique([adminId, permissionId])
}

model PlatformAuditLog {
  id Int @id @default(autoincrement())
  adminId Int
  action     String
  targetType String
  targetId   String?
  ipAddress  String?
  diffJson   Json?
  createdAt  DateTime @default(now())

  admin PlatformAdmin @relation(fields: [adminId], references: [id])

  @@index([adminId, createdAt])
}

model AccountAuditLog {
  id Int @id @default(autoincrement())
  accountId Int
  userId Int
  action     String
  targetType String
  targetId   String?
  ipAddress  String?
  diffJson   Json?
  createdAt  DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([accountId, createdAt])
  @@index([userId, createdAt])
}

model PlatformSetting {
  id Int @id @default(autoincrement())
  key       String   @unique
  valueJson Json
  updatedAt DateTime @updatedAt
}

model TemplateLibrary {
  id Int @id @default(autoincrement())
  type        TemplateType
  name        String
  description String?
  contentJson Json
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  versions TemplateVersion[]
}

model TemplateVersion {
  id Int @id @default(autoincrement())
  templateId Int
  version     Int
  contentJson Json
  createdAt   DateTime @default(now())

  template TemplateLibrary @relation(fields: [templateId], references: [id])

  @@unique([templateId, version])
}

model HealthCheck {
  id Int @id @default(autoincrement())
  name      String
  status    String
  checkedAt DateTime @default(now())
  details   Json?
}

model MonitoringMetric {
  id Int @id @default(autoincrement())
  name      String
  value     Float
  createdAt DateTime @default(now())
}

model SystemAlert {
  id Int @id @default(autoincrement())
  level      String
  message    String
  details    Json?
  createdAt  DateTime @default(now())
  resolvedAt DateTime?
}
model Account {
  id Int @id @default(autoincrement())
  name      String
  slug      String        @unique
  status    AccountStatus @default(ACTIVE)
  timeZone  String
  planId Int?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  plan              PlatformPlan?        @relation(fields: [planId], references: [id])
  platformSubscriptions PlatformSubscription[]
  platformInvoices PlatformInvoice[]
  platformLimits   PlatformLimit[]
  settings          AccountSetting?
  branding          AccountBranding?
  domains           AccountDomain[]
  publicPages       PublicPage[]
  seoSettings       SeoSetting?
  mediaCollections  MediaCollection[]
  locations         Location[]
  locationManagers  LocationManager[]
  services          Service[]
  serviceCategories ServiceCategory[]
  roles             Role[]
  users             RoleAssignment[]
  clients           Client[]
  clientTags        ClientTag[]
  specialistProfiles SpecialistProfile[]
    appointments      Appointment[]
    appointmentHolds  AppointmentHold[]
    scheduleTemplates ScheduleTemplate[]
    scheduleEntries   ScheduleEntry[]
    scheduleNonWorkingTypes ScheduleNonWorkingType[]
    blockedSlots      BlockedSlot[]
  userSessions      UserSession[]
  paymentIntents    PaymentIntent[]
  transactions      Transaction[]
  refunds           Refund[]
  receipts          Receipt[]
  paymentMethods    PaymentMethod[]
  promotions        Promotion[]
  promoCodes        PromoCode[]
  referrals         Referral[]
  giftCards         GiftCard[]
  memberships       Membership[]
  loyaltyRules      LoyaltyRule[]
  loyaltyWallets    LoyaltyWallet[]
  reviews           Review[]
  ratingAggregates  RatingAggregate[]
  notifications     Notification[]
  notificationTemplates NotificationTemplate[]
  notificationPreferences NotificationPreference[]
  outboxItems       OutboxItem[]
  webhookEndpoints  WebhookEndpoint[]
  audits            AccountAuditLog[]

  @@index([status, createdAt])
}

model AccountSetting {
  id Int @id @default(autoincrement())
  accountId Int   @unique
  slotStepMinutes         Int      @default(15)
  requireDeposit          Boolean  @default(false)
  requirePaymentToConfirm Boolean  @default(false)
  cancellationWindowHours Int?
  rescheduleWindowHours   Int?
  holdTtlMinutes          Int?
  defaultReminderHours    Int?
  notificationQuietHours  Json?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id])
}

model AccountBranding {
  id Int @id @default(autoincrement())
  accountId Int   @unique
  logoUrl        String?
  coverUrl       String?
  accentColor    String?
  secondaryColor String?
  themePreset    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id])
}

model AccountDomain {
  id Int @id @default(autoincrement())
  accountId Int
  domain     String   @unique
  isPrimary  Boolean  @default(false)
  verifiedAt DateTime?
  createdAt  DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id])
}

model PublicPage {
  id Int @id @default(autoincrement())
  accountId Int
  status             PublicPageStatus @default(DRAFT)
  draftJson          Json?
  publishedVersionId Int? @unique
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  account          Account             @relation(fields: [accountId], references: [id])
  versions         PublicPageVersion[]
  publishedVersion PublicPageVersion?  @relation("PublishedVersion", fields: [publishedVersionId], references: [id])
  sections         PublicPageSection[]
  media            PublicPageMedia[]

  @@index([accountId, status])
}

model PublicPageVersion {
  id Int @id @default(autoincrement())
  publicPageId Int
  version      Int
  contentJson  Json
  createdAt    DateTime @default(now())

  publicPage  PublicPage  @relation(fields: [publicPageId], references: [id])
  publishedFor PublicPage? @relation("PublishedVersion")

  @@unique([publicPageId, version])
}

model PublicPageSection {
  id Int @id @default(autoincrement())
  publicPageId Int
  key         String
  title       String?
  sortOrder   Int
  isVisible   Boolean  @default(true)
  layoutPreset String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  publicPage PublicPage @relation(fields: [publicPageId], references: [id])
  blocks     PublicPageBlock[]

  @@index([publicPageId, sortOrder])
}

model PublicPageBlock {
  id Int @id @default(autoincrement())
  sectionId Int
  type      String
  contentJson Json
  sortOrder Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  section PublicPageSection @relation(fields: [sectionId], references: [id])

  @@index([sectionId, sortOrder])
}

model PublicPageMedia {
  id Int @id @default(autoincrement())
  publicPageId Int
  assetId Int
  sortOrder   Int
  createdAt   DateTime @default(now())

  publicPage PublicPage @relation(fields: [publicPageId], references: [id])
  asset      MediaAsset @relation(fields: [assetId], references: [id])

  @@index([publicPageId, sortOrder])
}

model SeoSetting {
  id Int @id @default(autoincrement())
  accountId Int   @unique
  title          String?
  description    String?
  ogImageUrl     String?
  schemaJson     Json?
  robots         String?
  sitemapEnabled Boolean  @default(true)
  updatedAt      DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id])
}

model Category {
  id Int @id @default(autoincrement())
  accountId Int?
  name      String
  slug      String
  createdAt DateTime @default(now())

  @@index([accountId])
}

model Tag {
  id Int @id @default(autoincrement())
  accountId Int?
  name      String
  slug      String
  createdAt DateTime @default(now())

  @@index([accountId])
}

model MediaAsset {
  id Int @id @default(autoincrement())
  accountId Int?
  url       String
  type      String
  width     Int?
  height    Int?
  size      Int?
  createdAt DateTime @default(now())

  links           MediaLink[]
  publicPageMedia PublicPageMedia[]
}

model MediaCollection {
  id Int @id @default(autoincrement())
  accountId Int
  name      String
  createdAt DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id])
  links   MediaLink[]
}

model MediaLink {
  id Int @id @default(autoincrement())
  assetId Int
  collectionId Int?
  entityType   String
  entityId     String
  sortOrder    Int     @default(0)
  isCover      Boolean @default(false)
  createdAt    DateTime @default(now())

  asset      MediaAsset       @relation(fields: [assetId], references: [id])
  collection MediaCollection? @relation(fields: [collectionId], references: [id])

  @@index([entityType, entityId])
  @@index([entityType, entityId, sortOrder])
}

model Review {
  id Int @id @default(autoincrement())
  accountId Int
  clientId Int
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id])
  client  Client  @relation(fields: [clientId], references: [id])
  votes   ReviewVote[]
}

model ReviewVote {
  id Int @id @default(autoincrement())
  reviewId Int
  userId Int?
  value     Int
  createdAt DateTime @default(now())

  review Review @relation(fields: [reviewId], references: [id])
  user   User?  @relation(fields: [userId], references: [id])
}

model RatingAggregate {
  id Int @id @default(autoincrement())
  accountId Int
  entityType  String
  entityId    String
  ratingAvg   Float
  ratingCount Int
  updatedAt   DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id])

  @@unique([entityType, entityId])
}

model Favorite {
  id Int @id @default(autoincrement())
  clientId Int
  entityType String
  entityId   String
  createdAt  DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id])

  @@unique([clientId, entityType, entityId])
}

model SearchIndex {
  id Int @id @default(autoincrement())
  accountId Int?
  entityType String
  entityId   String
  payload    Json
  updatedAt  DateTime @updatedAt

  @@index([accountId])
}

model GeoPoint {
  id Int @id @default(autoincrement())
  locationId Int   @unique
  lat        Float
  lng        Float

  location Location @relation(fields: [locationId], references: [id])
}

model Location {
  id Int @id @default(autoincrement())
  accountId Int
  name        String
  address     String
  phone       String?
  status      String @default("ACTIVE")
  websiteUrl  String?
  instagramUrl String?
  whatsappUrl  String?
  telegramUrl  String?
  maxUrl       String?
  vkUrl        String?
  viberUrl     String?
  pinterestUrl String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

    account     Account            @relation(fields: [accountId], references: [id])
    geoPoint    GeoPoint?
    hours       LocationHour[]
    scheduleEntries ScheduleEntry[]
  exceptions  LocationException[]
  services    ServiceLocation[]
  specialists SpecialistLocation[]
  managers    LocationManager[]
  appointments Appointment[]
  workingHours WorkingHour[]
  breaks       Break[]
  vacations    Vacation[]
  blockedSlots BlockedSlot[]

  @@index([accountId, createdAt])
}

model LocationHour {
  id Int @id @default(autoincrement())
  locationId Int
  dayOfWeek  Int
  startTime  String
  endTime    String

  location Location @relation(fields: [locationId], references: [id])

  @@index([locationId, dayOfWeek])
}

model LocationException {
  id Int @id @default(autoincrement())
  locationId Int
  date       DateTime
  isClosed   Boolean @default(false)
  startTime  String?
  endTime    String?

  location Location @relation(fields: [locationId], references: [id])
}

model User {
  id Int @id @default(autoincrement())
  email     String?   @unique
  phone     String?
  status    UserStatus @default(ACTIVE)
  type      UserType   @default(STAFF)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  profile          UserProfile?
  identities       UserIdentity[]
  sessions         UserSession[]
  roleAssignments  RoleAssignment[]
  specialistProfiles SpecialistProfile[]
  clientProfiles     Client[]
  notifications    Notification[]
  channelPreferences UserNotificationChannelPreference[]
  deviceTokens       DeviceToken[]
  reviewVotes        ReviewVote[]
  notificationPreferences NotificationPreference[]
  outboxItems         OutboxItem[]
  aiThreads           AiThread[]
  platformAdmin    PlatformAdmin?
  accountAudits    AccountAuditLog[]
  locationManagers LocationManager[]

  @@index([email])
}

model UserProfile {
  id Int @id @default(autoincrement())
  userId Int   @unique
  firstName String?
  lastName  String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model UserIdentity {
  id Int @id @default(autoincrement())
  userId Int
  provider       IdentityProvider
  providerUserId String?
  email          String?
  phone          String?
  passwordHash   String?
  passwordSalt   String?
  passwordAlgo   String?
  passwordUpdatedAt DateTime?
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([provider, providerUserId])
  @@unique([provider, email])
}

model UserSession {
  id Int @id @default(autoincrement())
  userId Int
  sessionType SessionType @default(PLATFORM)
  accountId Int?
  accessTokenHash  String   @unique
  accessExpiresAt  DateTime
  refreshTokenHash String   @unique
  refreshExpiresAt DateTime
  createdAt        DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id])
  account Account? @relation(fields: [accountId], references: [id])

  @@index([accountId])
}

model UserNotificationChannelPreference {
  id Int @id @default(autoincrement())
  userId Int
  channel   NotificationChannel
  enabled   Boolean             @default(true)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, channel])
}

model DeviceToken {
  id Int @id @default(autoincrement())
  userId Int
  platform  String
  token     String
  createdAt DateTime @default(now())
  lastSeenAt DateTime?

  user User @relation(fields: [userId], references: [id])

  @@unique([platform, token])
}

model Role {
  id Int @id @default(autoincrement())
  accountId Int
  name      RoleName
  createdAt DateTime @default(now())

  account     Account          @relation(fields: [accountId], references: [id])
  permissions RolePermission[]
  assignments RoleAssignment[]

  @@unique([accountId, name])
}

model Permission {
  id Int @id @default(autoincrement())
  key         String   @unique
  description String?
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]
}

model RolePermission {
  id Int @id @default(autoincrement())
  roleId Int
  permissionId Int

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
}

model RoleAssignment {
  id Int @id @default(autoincrement())
  userId Int
  accountId Int
  roleId Int
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  account Account @relation(fields: [accountId], references: [id])
  role    Role    @relation(fields: [roleId], references: [id])

  @@unique([userId, accountId])
}

model SpecialistLevel {
  id Int @id @default(autoincrement())
  accountId Int?
  name      String
  rank      Int
  createdAt DateTime @default(now())

  specialists SpecialistProfile[]
  levelHistory SpecialistLevelHistory[]
  serviceLevelConfigs ServiceLevelConfig[]
}

model SpecialistProfile {
  id Int @id @default(autoincrement())
  accountId Int
  userId Int
  levelId Int?
  bio       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account     Account          @relation(fields: [accountId], references: [id])
  user        User             @relation(fields: [userId], references: [id])
  level       SpecialistLevel? @relation(fields: [levelId], references: [id])
  services    SpecialistService[]
  locations   SpecialistLocation[]
    appointments Appointment[]
    appointmentHolds AppointmentHold[]
    workingHours WorkingHour[]
    breaks      Break[]
    vacations   Vacation[]
    scheduleEntries ScheduleEntry[]
    blockedSlots BlockedSlot[]
  levelHistory SpecialistLevelHistory[]

  @@unique([accountId, userId])
}

model SpecialistLevelHistory {
  id Int @id @default(autoincrement())
  specialistId Int
  levelId Int
  assignedAt   DateTime @default(now())

  specialist SpecialistProfile @relation(fields: [specialistId], references: [id])
  level      SpecialistLevel   @relation(fields: [levelId], references: [id])
}
model ServiceCategory {
  id Int @id @default(autoincrement())
  accountId Int?
  name      String
  slug      String
  createdAt DateTime @default(now())

  account  Account? @relation(fields: [accountId], references: [id])
  services Service[]
}

model Service {
  id Int @id @default(autoincrement())
  accountId Int
  categoryId Int?
  name            String
  description     String?
  baseDurationMin Int
  basePrice       Decimal  @db.Decimal(12, 2)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  account          Account          @relation(fields: [accountId], references: [id])
  category         ServiceCategory? @relation(fields: [categoryId], references: [id])
  variants         ServiceVariant[]
  levelConfigs     ServiceLevelConfig[]
  specialists      SpecialistService[]
  locations        ServiceLocation[]
  appointmentServices AppointmentService[]
}

model ServiceVariant {
  id Int @id @default(autoincrement())
  serviceId Int
  name        String
  durationMin Int?
  price       Decimal? @db.Decimal(12, 2)
  createdAt   DateTime @default(now())

  service Service @relation(fields: [serviceId], references: [id])
}

model ServiceLevelConfig {
  id Int @id @default(autoincrement())
  serviceId Int
  levelId Int
  durationMin Int?
  price       Decimal? @db.Decimal(12, 2)
  createdAt   DateTime @default(now())

  service Service         @relation(fields: [serviceId], references: [id])
  level   SpecialistLevel @relation(fields: [levelId], references: [id])

  @@unique([serviceId, levelId])
}

model SpecialistService {
  id Int @id @default(autoincrement())
  specialistId Int
  serviceId Int
  priceOverride       Decimal? @db.Decimal(12, 2)
  durationOverrideMin Int?
  createdAt           DateTime @default(now())

  specialist SpecialistProfile @relation(fields: [specialistId], references: [id])
  service    Service           @relation(fields: [serviceId], references: [id])

  @@unique([specialistId, serviceId])
}

model ServiceLocation {
  id Int @id @default(autoincrement())
  serviceId Int
  locationId Int

  service  Service  @relation(fields: [serviceId], references: [id])
  location Location @relation(fields: [locationId], references: [id])

  @@unique([serviceId, locationId])
}

model SpecialistLocation {
  id Int @id @default(autoincrement())
  specialistId Int
  locationId Int

  specialist SpecialistProfile @relation(fields: [specialistId], references: [id])
